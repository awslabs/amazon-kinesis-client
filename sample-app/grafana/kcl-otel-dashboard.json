{
  "annotations": {
    "list": []
  },
  "description": "KCL (Amazon Kinesis Client Library) metrics via OpenTelemetry - end-to-end observability dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5000 }, { "color": "red", "value": 30000 }] }, "unit": "ms" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Millis Behind Latest",
      "type": "stat",
      "targets": [{ "expr": "max(MillisBehindLatest{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"})", "legendFormat": "Max Behind" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Records Processed (rate/s)",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(RecordsProcessed_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m]))", "legendFormat": "Records/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Current Leases",
      "type": "stat",
      "targets": [{ "expr": "sum(CurrentLeases{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Leases" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Lost Leases",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(LostLeases{aws_kinesis_consumer_name=~\"$consumer\"}[5m]))", "legendFormat": "Lost/s" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Record Processing",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "MillisBehindLatest by Shard",
      "type": "timeseries",
      "targets": [{ "expr": "MillisBehindLatest{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\", aws_kinesis_shard_id=~\"$shard\"}", "legendFormat": "{{aws_kinesis_shard_id}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Records Processed Rate by Shard",
      "type": "timeseries",
      "targets": [{ "expr": "rate(RecordsProcessed_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\", aws_kinesis_shard_id=~\"$shard\"}[5m])", "legendFormat": "{{aws_kinesis_shard_id}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "decbytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Data Bytes Processed Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(DataBytesProcessed_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\", aws_kinesis_shard_id=~\"$shard\"}[5m])", "legendFormat": "{{aws_kinesis_shard_id}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "RecordProcessor.processRecords Latency (p99)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(RecordProcessor_processRecords_bucket{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (le, aws_kinesis_shard_id))", "legendFormat": "p99 {{aws_kinesis_shard_id}}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Lease Management",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Lease Counts",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(CurrentLeases{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Current Leases" },
        { "expr": "sum(TotalLeases{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Total Leases" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Lease Activity",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(TakenLeases{aws_kinesis_consumer_name=~\"$consumer\"}[5m]))", "legendFormat": "Taken/s" },
        { "expr": "sum(rate(LostLeases{aws_kinesis_consumer_name=~\"$consumer\"}[5m]))", "legendFormat": "Lost/s" },
        { "expr": "sum(rate(ExpiredLeases{aws_kinesis_consumer_name=~\"$consumer\"}[5m]))", "legendFormat": "Expired/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Workers & Lease Balance",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(NumWorkers{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Workers" },
        { "expr": "sum(UntakenLeases{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Untaken Leases" },
        { "expr": "sum(VeryOldLeases{aws_kinesis_consumer_name=~\"$consumer\"})", "legendFormat": "Very Old Leases" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Operation Latency & Success",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Operation Time by Operation",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(Time_bucket{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (le, aws_kinesis_operation))", "legendFormat": "p99 {{aws_kinesis_operation}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 31,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Success Rate by Operation",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(Success_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (aws_kinesis_operation) / (sum(rate(Success_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (aws_kinesis_operation) + sum(rate(Fault_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (aws_kinesis_operation))", "legendFormat": "{{aws_kinesis_operation}}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Iterator & Fetcher",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 40,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "Expired Iterators",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(ExpiredIterator{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (aws_kinesis_shard_id)", "legendFormat": "{{aws_kinesis_shard_id}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 41,
      "options": { "tooltip": { "mode": "multi" } },
      "title": "KinesisDataFetcher Latency (p99)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, sum(rate(KinesisDataFetcher_Time_bucket{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}[5m])) by (le))", "legendFormat": "p99 GetRecords" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kcl", "kinesis", "otel", "cloudwatch"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(RecordsProcessed_count, aws_kinesis_consumer_name)",
        "name": "consumer",
        "label": "Consumer App",
        "type": "query",
        "refresh": 2,
        "multi": false,
        "includeAll": true
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(RecordsProcessed_count{aws_kinesis_consumer_name=~\"$consumer\"}, aws_kinesis_stream_name)",
        "name": "stream",
        "label": "Stream",
        "type": "query",
        "refresh": 2,
        "multi": false,
        "includeAll": true
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(RecordsProcessed_count{aws_kinesis_consumer_name=~\"$consumer\", aws_kinesis_stream_name=~\"$stream\"}, aws_kinesis_shard_id)",
        "name": "shard",
        "label": "Shard",
        "type": "query",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "KCL OpenTelemetry Metrics",
  "uid": "kcl-otel-metrics",
  "version": 1
}
